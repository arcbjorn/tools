#!/usr/bin/env bash
#
# tools - single entry point for this tools repo.
#
#   tools                 interactive menu (autodiscovers bin/ + scripts/)
#   tools menu            same as above
#   tools build           compile everything in sources/  -> bin/
#   tools submodules      update all git submodules to latest
#   tools permissions     fix executable permissions on bin/ + scripts/
#   tools init            full setup (build + configure shell + permissions)
#   tools assist <cmd>    assistant config (gen|sync|doctor|import) via assistants-cli
#   tools agents [roles]  launch orchestrated CLI agent swarm in tmux
#   tools help            this help
#
set -euo pipefail

TOOLS_DIR="$HOME/tools"
MGMT_DIR="$TOOLS_DIR/tools_management"
ASSIST_CLI="$TOOLS_DIR/sources/assistants-cli/cli.ts"

# Theme-aware colors (omarchy terminal palette slots)
RED='\033[38;5;1m'; GREEN='\033[38;5;2m'; YELLOW='\033[38;5;3m'
BLUE='\033[38;5;4m'; MAGENTA='\033[38;5;5m'; CYAN='\033[38;5;6m'
WHITE='\033[38;5;7m'; GRAY='\033[38;5;8m'; NC='\033[0m'

die() { echo -e "${RED}error:${NC} $*" >&2; exit 1; }

usage() {
    sed -n '3,12p' "$0" | sed 's/^# \{0,1\}//'
}

run_mgmt() {
    local script="$1"; shift || true
    local path="$MGMT_DIR/$script"
    [[ -f "$path" ]] || die "missing $path"
    [[ -x "$path" ]] || chmod +x "$path"
    "$path" "$@"
}

run_agents() {
    local script="$TOOLS_DIR/sources/arkestra/arkestra.sh"
    [[ -f "$script" ]] || die "missing $script (is the submodule checked out?)"
    [[ -x "$script" ]] || chmod +x "$script"
    "$script" "$@"
}

run_assist() {
    command -v bun >/dev/null 2>&1 || die "bun is required for 'tools assist' (https://bun.sh)"
    [[ -f "$ASSIST_CLI" ]] || die "missing $ASSIST_CLI (is the submodule checked out?)"
    local sub="${1:-}"; shift || true
    case "$sub" in
        gen)    bun run "$ASSIST_CLI" gen "${1:-all}" "${@:2}" ;;
        sync)   bun run "$ASSIST_CLI" sync-global "$@" ;;
        doctor) bun run "$ASSIST_CLI" doctor "$@" ;;
        import) bun run "$ASSIST_CLI" sync-from-global "$@" ;;
        ""|help|-h|--help)
            echo -e "${CYAN}tools assist <cmd>${NC}"
            echo "  gen [all|claude|codex|gemini|opencode|pi]   regenerate assistant configs from source/"
            echo "  sync [--dry]                                push generated configs to global dirs"
            echo "  doctor                                      check assistant config health"
            echo "  import [--dry]                              import global commands/agents into source/"
            ;;
        *) die "unknown assist command '$sub' (try: tools assist help)" ;;
    esac
}

# One-line description for a discovered tool. Unknown tools fall back to their name.
describe() {
    case "$1" in
        assistants-cli)        echo "Generate/sync/check AI assistant configs" ;;
        attach-existing-repo)  echo "Attach an existing project dir to a new remote repo" ;;
        init-new-repo)         echo "Create a new repo with full configuration" ;;
        git-status-overview)   echo "Git status overview for ~/tools and ~/projects" ;;
        configure-cc-glm)      echo "Add 'glm' shell function (api.z.ai)" ;;
        passcopy)              echo "Copy a field from a pass entry to the clipboard" ;;
        workflow)              echo "Workflow tool" ;;
        gh-activity-graph-sh)  echo "Render a GitHub activity graph" ;;
        tools)                 echo "" ;;  # hide self
        *)                     echo "" ;;
    esac
}

# Interactive picker: autodiscover every executable in bin/ and scripts/.
menu() {
    command -v gum >/dev/null 2>&1 || die "gum is required for the menu (brew install gum / pacman -S gum)"

    local -a rows=()
    local d name desc
    for d in "$TOOLS_DIR/bin" "$TOOLS_DIR/scripts"; do
        [[ -d "$d" ]] || continue
        while IFS= read -r f; do
            name="$(basename "$f")"
            [[ "$name" == "tools" ]] && continue   # never list self
            desc="$(describe "$name")"
            if [[ -n "$desc" ]]; then
                rows+=("$name — $desc")
            else
                rows+=("$name")
            fi
        done < <(find "$d" -maxdepth 1 -type f -perm -u+x | sort)
    done

    [[ ${#rows[@]} -gt 0 ]] || die "no executables found in bin/ or scripts/ (run: tools build)"

    local choice
    choice="$(printf '%s\n' "${rows[@]}" | gum filter \
        --placeholder "search tools..." \
        --prompt "→ " \
        --indicator "→" \
        --height 20 || true)"
    [[ -n "$choice" ]] || { echo -e "${GRAY}cancelled${NC}"; return 0; }

    local tool="${choice%% — *}"
    echo -e "${MAGENTA}running:${NC} ${GREEN}$tool${NC}"
    echo "────────────────────────────────────────"
    "$tool"
}

main() {
    local cmd="${1:-menu}"; shift || true
    case "$cmd" in
        menu)                 menu ;;
        build)                run_mgmt build.sh "$@" ;;
        submodules|sync-submodules) run_mgmt sync-submodules.sh "$@" ;;
        permissions|set-permissions) run_mgmt set-permissions.sh "$@" ;;
        init)                 run_mgmt init-tools.sh "$@" ;;
        configure-shell)      run_mgmt configure-shell.sh "$@" ;;
        new-tool)             run_mgmt init-new-tool.sh "$@" ;;
        assist)               run_assist "$@" ;;
        agents)               run_agents "$@" ;;
        help|-h|--help)       usage ;;
        *) die "unknown command '$cmd' (try: tools help)" ;;
    esac
}

main "$@"
