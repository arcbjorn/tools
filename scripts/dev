#!/usr/bin/env bash
#
# dev - open a project dev session in tmux (e.g. frontend + backend panes).
#
#   tools dev            launch the session from .tools-dev (or a generic split)
#   tools dev set        interactive builder: define 2-4 panes -> writes .tools-dev
#   tools dev edit       open .tools-dev in $EDITOR
#   tools dev stop       kill this project's dev session
#
# Config: a `.tools-dev` file in the repo root, one pane per line:
#     <name> | <dir> | <command>
#   e.g.
#     web | ./web | pnpm dev
#     api | ./api | pnpm start:dev
# Lines starting with # are ignored. `dir` is relative to the repo root.
# No config? -> a generic 2-pane split in the current dir, and you're offered to
# save it as .tools-dev for next time.
#
# bash 3.2 safe (macOS default).
set -eu

BLUE='\033[38;5;4m'; GREEN='\033[38;5;2m'; YELLOW='\033[38;5;3m'
CYAN='\033[38;5;6m'; GRAY='\033[38;5;8m'; B='\033[1m'; DIM='\033[2m'; NC='\033[0m'
die() { printf "\033[38;5;1m✗${NC} %s\n" "$*" >&2; exit 1; }

HAS_GUM=0; [ "${TOOLS_DEV_NO_GUM:-0}" != 1 ] && command -v gum >/dev/null 2>&1 && HAS_GUM=1
ui_input() {  # <prompt> [default]
  if [ "$HAS_GUM" = 1 ]; then gum input --prompt="  $1 " --value="${2:-}" 2>/dev/tty
  else printf "  %s [%s] " "$1" "${2:-}" >&2; local v; read -r v || true; printf '%s' "${v:-${2:-}}"; fi
}
ui_choose() {  # <header> <newline-opts>
  if [ "$HAS_GUM" = 1 ]; then printf '%s' "$2" | gum choose --header="$1" --cursor="❯ " --cursor.foreground=2 2>/dev/tty
  else printf "${DIM}%s${NC}\n" "$1" >&2; local i=1; printf '%s\n' "$2" | while IFS= read -r o; do [ -n "$o" ] && printf "  %2d %s\n" "$i" "$o" >&2; i=$((i+1)); done
    printf "  number: " >&2; local p; read -r p || true; printf '%s' "$2" | sed -n "${p}p"; fi
}

command -v tmux >/dev/null 2>&1 || die "tmux is required"
ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
CONF="$ROOT/.tools-dev"
# session name from the project dir, sanitized: dev-<basename>
SESSION="dev-$(basename "$ROOT" | tr -c 'A-Za-z0-9_-' '-' | sed 's/-*$//')"

# ---- tmux styling (clean status bar; matches the house look) ----
style() {
  local s="$1"
  tmux set -t "$s" mouse on
  tmux set -t "$s" status-position top
  tmux set -t "$s" status-justify left
  tmux set -t "$s" status-style "bg=colour0,fg=colour8"
  tmux set -t "$s" status-left " #[fg=colour4,bold]dev#[default] #[fg=colour8]${SESSION#dev-}   "
  tmux set -t "$s" status-left-length 30
  tmux set -t "$s" status-right "#[fg=colour8]%H:%M "
  tmux set -t "$s" status-right-length 10
  tmux setw -g window-status-format         "#[fg=colour8] #W #[default]"
  tmux setw -g window-status-current-format "#[fg=colour2,bold] #W #[default]"
  tmux setw -g window-status-separator " "
  tmux set -t "$s" pane-border-status top
  tmux set -t "$s" pane-border-format " #{?pane_active,#[fg=colour2 bold],#[fg=colour8]}#{pane_title} "
  tmux set -t "$s" pane-active-border-style "fg=colour2"
  tmux set -t "$s" pane-border-style "fg=colour8"
  tmux set -t "$s" automatic-rename off
}

# ---- read .tools-dev into parallel arrays (bash 3.2: no assoc) ----
NAMES=""; DIRS=""; CMDS=""; N=0
load_conf() {
  [ -f "$CONF" ] || return 1
  while IFS= read -r line; do
    case "$line" in ''|'#'*) continue ;; esac
    local nm dr cm
    nm=$(printf '%s' "$line" | awk -F'|' '{gsub(/^ +| +$/,"",$1); print $1}')
    dr=$(printf '%s' "$line" | awk -F'|' '{gsub(/^ +| +$/,"",$2); print $2}')
    cm=$(printf '%s' "$line" | awk -F'|' '{sub(/^[^|]*\|[^|]*\|/,""); gsub(/^ +| +$/,"",$0); print}')
    [ -n "$nm" ] || continue
    NAMES="$NAMES$nm
"; DIRS="$DIRS$dr
"; CMDS="$CMDS$cm
"; N=$((N+1))
  done < "$CONF"
  [ "$N" -gt 0 ]
}

nth() { printf '%s\n' "$1" | sed -n "$2p"; }

pdir_of() { local d="$ROOT/$1"; [ -d "$d" ] && echo "$d" || echo "$ROOT"; }

launch() {
  tmux has-session -t "$SESSION" 2>/dev/null && {
    printf "${YELLOW}!${NC} '%s' already running — ${B}tmux attach -t %s${NC}\n" "$SESSION" "$SESSION" >&2
    return 0
  }
  [ "$N" -gt 4 ] && N=4   # one screen holds up to 4 cleanly

  tmux new-session -d -s "$SESSION" -c "$(pdir_of "$(nth "$DIRS" 1)")"
  style "$SESSION"

  # create the remaining panes (split direction picked for a clean smart layout).
  local i=2
  while [ "$i" -le "$N" ]; do
    local pdir; pdir=$(pdir_of "$(nth "$DIRS" "$i")")
    case "$N:$i" in
      2:2)   tmux split-window -h -t "$SESSION" -c "$pdir" ;;        # side by side
      3:2)   tmux split-window -h -t "$SESSION" -c "$pdir" ;;        # one left | two right
      3:3)   tmux split-window -v -t "$SESSION:.1" -c "$pdir" ;;     # stack the right column
      4:*)   tmux split-window -h -t "$SESSION" -c "$pdir" ;;        # 2x2 via tiled below
    esac
    i=$((i+1))
  done

  # smart layout per pane count
  case "$N" in
    2) tmux select-layout -t "$SESSION" even-horizontal ;;
    3) tmux set -t "$SESSION" main-pane-width "50%" 2>/dev/null \
         || tmux setw -t "$SESSION" main-pane-width 80
       tmux select-layout -t "$SESSION" main-vertical ;;           # left half, two stacked right
    4) tmux select-layout -t "$SESSION" tiled ;;                   # 2x2 grid
  esac

  # title each pane and run its command. Panes with no command get a one-line
  # hint so an empty shell isn't mysterious.
  i=1
  while [ "$i" -le "$N" ]; do
    local nm cm; nm=$(nth "$NAMES" "$i"); cm=$(nth "$CMDS" "$i")
    tmux select-pane -t "$SESSION:.$((i-1))" -T "$nm"
    if [ -n "$cm" ]; then
      tmux send-keys -t "$SESSION:.$((i-1))" "clear; $cm" Enter
    else
      tmux send-keys -t "$SESSION:.$((i-1))" \
        "clear; printf '\033[2m[%s] no command — set one with: tools dev set\033[0m\n' '$nm'" Enter
    fi
    i=$((i+1))
  done
  tmux select-pane -t "$SESSION:.0"
  printf "${GREEN}✓${NC} dev session ${B}%s${NC} (%d panes)\n" "$SESSION" "$N" >&2
  printf "  ${DIM}reconfigure: ${NC}${B}tools dev set${NC}${DIM}   ·   stop: ${NC}${B}tools dev stop${NC}\n" >&2

  # auto-attach — but NOT if already inside tmux (nested attach is refused).
  if [ -n "${TMUX:-}" ]; then
    tmux switch-client -t "$SESSION" 2>/dev/null \
      || printf "  ${YELLOW}!${NC} inside tmux — ${B}tmux switch-client -t %s${NC}\n" "$SESSION" >&2
  else
    exec tmux attach -t "$SESSION"
  fi
}

# ---- interactive builder: write .tools-dev (panes count -> name/dir/command) ----
cmd_set() {
  printf "\n${B}${BLUE}configure dev session${NC} ${DIM}%s${NC}\n" "$ROOT" >&2
  # pre-fill from the existing config so changing one thing = press Enter through
  # the rest. (load_conf populates NAMES/DIRS/CMDS/N.)
  load_conf || true
  local cur_n="$N"
  [ "$cur_n" -gt 0 ] 2>/dev/null && printf "  ${DIM}editing existing (%d panes) — Enter keeps a value${NC}\n" "$cur_n" >&2

  local count; count=$(ui_choose "how many panes?${cur_n:+ (now $cur_n)}" "2
3
4")
  count="${count%% *}"
  case "$count" in 2|3|4) :;; *) die "pick 2, 3, or 4" ;; esac

  local body="" i=1
  while [ "$i" -le "$count" ]; do
    local nm dr cm dnm ddr dcm
    dnm=$(nth "$NAMES" "$i"); ddr=$(nth "$DIRS" "$i"); dcm=$(nth "$CMDS" "$i")
    # header shows the CURRENT values so you always have context while typing.
    printf "\n${B}${CYAN}pane %d of %d${NC}" "$i" "$count" >&2
    if [ -n "$dnm" ]; then printf "  ${DIM}current: %s | %s | %s${NC}" "$dnm" "${ddr:-.}" "${dcm:-—}" >&2; fi
    printf "\n" >&2
    nm=$(ui_input "name:" "${dnm:-pane$i}")
    dr=$(ui_input "dir (relative to repo root):" "${ddr:-.}")
    cm=$(ui_input "command (blank = just a shell):" "$dcm")
    # echo back what was captured (gum clears its own line, so confirm it here).
    printf "  ${GREEN}✓${NC} ${B}%s${NC} ${GRAY}|${NC} %s ${GRAY}|${NC} %s\n" "$nm" "$dr" "${cm:-${DIM}(shell)${NC}}" >&2
    body="$body$nm | $dr | $cm
"
    i=$((i+1))
  done

  { printf '# tools dev layout for %s\n' "$(basename "$ROOT")"
    printf '# format: <name> | <dir> | <command>\n'
    printf '%s' "$body"; } > "$CONF"
  # final summary so you see the whole config at a glance.
  printf "\n${GREEN}✓${NC} saved ${B}%s${NC} ${DIM}(%d panes)${NC}\n" "$CONF" "$count" >&2
  printf '%s' "$body" | while IFS='|' read -r sn sd sc; do
    printf "    ${CYAN}%s${NC} ${GRAY}·${NC} %s ${GRAY}·${NC} %s\n" \
      "$(echo "$sn" | sed 's/ *$//')" "$(echo "$sd" | sed 's/^ *//;s/ *$//')" "$(echo "$sc" | sed 's/^ *//')" >&2
  done
  printf "  ${DIM}launch: ${NC}${B}tools dev${NC}\n" >&2
}

# ---- generic fallback: 2-pane split, offer to save ----
generic_then_offer_save() {
  printf "${DIM}no .tools-dev — generic 2-pane split in %s${NC}\n" "$ROOT" >&2
  NAMES="left
right"; DIRS=".
."; CMDS="
"; N=2
  launch
  printf "\n${GRAY}tip: run ${NC}${B}tools dev set${NC}${GRAY} to define named panes that auto-run your commands.${NC}\n" >&2
}

case "${1:-}" in
  set)   cmd_set ;;
  edit)  "${EDITOR:-vi}" "$CONF" ;;
  stop)  tmux kill-session -t "$SESSION" 2>/dev/null \
           && printf "${GREEN}✓${NC} stopped %s\n" "$SESSION" >&2 \
           || printf "${GRAY}no '%s' session.${NC}\n" "$SESSION" >&2 ;;
  ""|start)
         if load_conf; then launch; else generic_then_offer_save; fi ;;
  *)     die "usage: tools dev [set|edit|stop]" ;;
esac
