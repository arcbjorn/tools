# SSH/Network shortcuts
# Resolve a tailnet host by name to its IP via `tailscale status`, then SSH to the
# IP directly. This works even when MagicDNS is down: it bypasses name resolution
# entirely (both the system resolver and `tailscale ssh`'s reverse-name lookup,
# both of which fail when MagicDNS isn't applied to the device).
_ts_ssh() {
    local host="$1"; shift
    if ! command -v tailscale >/dev/null 2>&1; then
        echo "tailscale not found in PATH" >&2
        return 1
    fi
    local ip
    ip="$(tailscale status 2>/dev/null | awk -v h="$host" '$2 == h {print $1; exit}')"
    if [ -z "$ip" ]; then
        echo "could not resolve tailnet host '$host' (is it in 'tailscale status'?)" >&2
        return 1
    fi
    ssh "admin@$ip" "$@"
}
alias base='_ts_ssh base'
alias nova='_ts_ssh nova'
alias status='tailscale status'

# Tools shortcuts
alias wf='workflow'

# GitHub shortcuts
alias view-repo='gh repo view --web'

# Show all shortcuts with syntax highlighting
shortcuts() {
    echo ""
    echo "=== Shell Shortcuts ==="
    echo ""

    echo "Git Commands:"
    cat ~/tools/shell/shortcuts | grep "^alias g" | sort | bat --language=bash --style=plain --color=always
    echo ""

    echo "File Listing:"
    cat ~/tools/shell/shortcuts | grep "^alias l" | sort | bat --language=bash --style=plain --color=always
    echo ""

    echo "Claude:"
    cat ~/tools/shell/shortcuts | grep "^alias c" | sort | bat --language=bash --style=plain --color=always
    echo ""

    echo "SSH/Network:"
    cat ~/tools/shell/shortcuts | grep -E "^alias (base|nova|status)" | sort | bat --language=bash --style=plain --color=always
    echo ""

    echo "Tools:"
    cat ~/tools/shell/shortcuts | grep "^alias w" | sort | bat --language=bash --style=plain --color=always
    echo ""

    echo "GitHub:"
    cat ~/tools/shell/shortcuts | grep "^alias view-" | sort | bat --language=bash --style=plain --color=always
    echo ""
}
