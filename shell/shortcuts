# SSH/Network shortcuts
# Resolve a tailnet host by name to its IP via `tailscale status`, then SSH to the
# IP directly. This works even when MagicDNS is down: it bypasses name resolution
# entirely (both the system resolver and `tailscale ssh`'s reverse-name lookup,
# both of which fail when MagicDNS isn't applied to the device).
# Portable across Linux (tailscale in PATH) and macOS (PATH or the GUI app bundle).
_ts_bin() {
    if command -v tailscale >/dev/null 2>&1; then
        echo tailscale
    elif [ -x /Applications/Tailscale.app/Contents/MacOS/Tailscale ]; then
        echo /Applications/Tailscale.app/Contents/MacOS/Tailscale
    else
        return 1
    fi
}
_ts_ssh() {
    local host="$1"; shift
    local ts
    ts="$(_ts_bin)" || { echo "tailscale not found in PATH or /Applications" >&2; return 1; }
    local ip
    ip="$("$ts" status 2>/dev/null | awk -v h="$host" '$2 == h {print $1; exit}')"
    if [ -z "$ip" ]; then
        echo "could not resolve tailnet host '$host' (is it in 'tailscale status'?)" >&2
        return 1
    fi
    ssh "admin@$ip" "$@"
}
alias base='_ts_ssh base'
alias nova='_ts_ssh nova'
alias status='tailscale status'

# Tools shortcuts
alias wf='workflow'

# GitHub shortcuts
alias view-repo='gh repo view --web'

_shortcuts_render() {
    if command -v bat >/dev/null 2>&1; then
        bat --language=bash --style=plain --color=always
    else
        cat
    fi
}

# Show all shortcuts with syntax highlighting
shortcuts() {
    echo ""
    echo "=== Shell Shortcuts ==="
    echo ""

    echo "Git Commands:"
    {
        grep "^alias g" ~/tools/shell/shortcuts
        echo "gcgp='opencode commit + git push'"
    } | sort | _shortcuts_render
    echo ""

    echo "File Listing:"
    grep "^alias l" ~/tools/shell/shortcuts | sort | _shortcuts_render
    echo ""

    echo "Claude:"
    grep "^alias c" ~/tools/shell/shortcuts | sort | _shortcuts_render
    echo ""

    echo "SSH/Network:"
    grep -E "^alias (base|nova|status)" ~/tools/shell/shortcuts | sort | _shortcuts_render
    echo ""

    echo "Tools:"
    grep "^alias w" ~/tools/shell/shortcuts | sort | _shortcuts_render
    echo ""

    echo "GitHub:"
    grep "^alias view-" ~/tools/shell/shortcuts | sort | _shortcuts_render
    echo ""
}
